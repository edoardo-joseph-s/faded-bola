{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "vercel-php@0.6.1",
      "config": {
        "includeFiles": [
          "app/**",
          "bootstrap/**",
          "config/**",
          "database/**",
          "public/**",
          "resources/**",
          "routes/**",
          "storage/**",
          "vendor/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "^/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "^/assets/(.*)",
      "dest": "public/assets/$1"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false",
    "LOG_CHANNEL": "stderr"
  }
}
