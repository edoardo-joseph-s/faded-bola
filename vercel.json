{
  "version": 2,
  "builds": [
    {
      "src": "public/index.php",
      "use": "@vercel/php",
      "config": {
        "includeFiles": [
          "vendor/**",
          "app/**",
          "bootstrap/**",
          "config/**",
          "database/**",
          "resources/views/**",
          "routes/**",
          "public/assets/**",
          "public/build/**"
        ]
      }
    }
  ],
  "routes": [
    {
      "src": "^/assets/(.*)",
      "dest": "public/assets/$1"
    },
    {
      "src": "^/build/(.*)",
      "dest": "public/build/$1"
    },
    {
      "src": "^/favicon.ico",
      "dest": "public/favicon.ico"
    },
    {
      "src": "^/robots.txt",
      "dest": "public/robots.txt"
    },
    {
      "src": "/(.*)",
      "dest": "public/index.php"
    }
  ],
  "env": {
    "APP_ENV": "production",
    "APP_DEBUG": "false"
  }
}
